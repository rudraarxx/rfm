<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RFM" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomSheetDialogTheme">@style/Theme.RFM.BottomSheet</item>
        <item name="chipStyle">@style/Widget.RFM.Chip</item>
    </style>

    <style name="Theme.RFM.Starting" parent="Theme.SplashScreen">
        <!-- The background color of the Android 12 Splash Screen -->
        <item name="windowSplashScreenBackground">#EFE8FE</item>
        <!-- The center icon (radio) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_vintage_radio</item>
        <!-- Explicitly set the icon background to transparent to avoid the system circle -->
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- The theme to load for the activity itself after the splash screen is drawn -->
        <item name="postSplashScreenTheme">@style/Theme.RFM</item>
    </style>

    <style name="Widget.RFM.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Theme.RFM.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.RFM.BottomSheet</item>
    </style>

    <style name="Widget.RFM.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@color/surface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.RFM.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.RFM.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>
</resources>
