<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="170dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_station_card"
    android:padding="12dp"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/iv_station_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_radio"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_station_icon"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/visualizer"
        layout="@layout/view_visualizer"
        android:layout_width="32dp"
        android:layout_height="20dp"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/iv_station_icon"
        app:layout_constraintBottom_toBottomOf="@id/iv_station_icon"
        app:layout_constraintStart_toStartOf="@id/iv_station_icon"
        app:layout_constraintEnd_toEndOf="@id/iv_station_icon" />

    <ImageView
        android:id="@+id/iv_play_overlay"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_play"
        android:tint="@color/text_primary"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/iv_station_icon"
        app:layout_constraintBottom_toBottomOf="@id/iv_station_icon"
        app:layout_constraintStart_toStartOf="@id/iv_station_icon"
        app:layout_constraintEnd_toEndOf="@id/iv_station_icon" />

    <TextView
        android:id="@+id/tv_station_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/iv_station_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_station_tag"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_station_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_favorite"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_favorite"
        android:tint="@color/accent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
